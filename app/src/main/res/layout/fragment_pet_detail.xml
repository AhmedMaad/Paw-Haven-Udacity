<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="32dp"
    tools:context=".PetDetailFragment">

    <ImageView
        android:id="@+id/animal_iv"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/ic_dog" />

    <TextView
        android:id="@+id/animal_name_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp"
        android:textColor="@color/black"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/animal_iv"
        app:layout_constraintTop_toTopOf="@id/animal_iv"
        tools:text="Bella" />

    <TextView
        android:id="@+id/animal_age_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="@id/animal_name_tv"
        app:layout_constraintTop_toBottomOf="@id/animal_name_tv"
        tools:text="2 years" />

    <com.udacity.pawhaven.components.PlayPauseComponent
        android:id="@+id/play_pause_view"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        app:layout_constraintEnd_toEndOf="@id/details_container"
        app:layout_constraintTop_toBottomOf="@id/animal_iv" />

    <ImageButton
        android:id="@+id/share_ib"
        android:layout_width="60dp"
        android:layout_height="40dp"
        android:background="@color/pawhaven_orange"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_share"
        app:layout_constraintBottom_toBottomOf="@id/play_pause_view"
        app:layout_constraintEnd_toStartOf="@id/play_pause_view"
        app:layout_constraintTop_toTopOf="@id/play_pause_view"
        app:tint="@color/white" />

    <LinearLayout
        android:id="@+id/details_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintTop_toBottomOf="@id/share_ib">

        <TextView
            android:id="@+id/description_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="24sp"
            tools:text="@string/description" />

        <Button
            android:id="@+id/adopt_a_paw_btn"
            style="@style/Widget.PawHaven.Button"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="32dp"
            android:text="@string/adopt_a_paw"
            android:textSize="28sp"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>